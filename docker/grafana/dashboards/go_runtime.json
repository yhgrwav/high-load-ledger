{
  "editable": true,
  "id": null,
  "title": "Go Runtime Monitoring",
  "tags": ["infrastructure"],
  "style": "dark",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Runtime: Active Goroutines",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "go_goroutines",
          "legendFormat": "Goroutines"
        }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 2,
      "title": "Runtime: Heap Memory Allocation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "go_memstats_alloc_bytes",
          "legendFormat": "Allocated Bytes"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "fieldConfig": { "defaults": { "unit": "bytes" } }
      }
    },
    {
      "id": 3,
      "title": "Runtime: GC Duration Quantiles (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "go_gc_duration_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99 GC Pause"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "fieldConfig": { "defaults": { "unit": "s" } }
      }
    }
  ]
}