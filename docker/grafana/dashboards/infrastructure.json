{
  "uid": "ledger-infrastructure",
  "title": "Инфраструктура (Nginx, Postgres, Redis)",
  "tags": ["infrastructure"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Nginx: активные соединения",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nginx_connections_active{job=\"nginx\"}",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nginx_connections_waiting{job=\"nginx\"}",
          "legendFormat": "waiting"
        }
      ]
    },
    {
      "id": 2,
      "title": "Nginx: принятые соединения / сек",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(nginx_connections_accepted{job=\"nginx\"}[1m])",
          "legendFormat": "accepted/s"
        }
      ]
    },
    {
      "id": 3,
      "title": "Nginx: обработано запросов / сек",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(nginx_http_requests_total{job=\"nginx\"}[1m])",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "Postgres: подключения к БД ledger",
      "description": "Число активных сессий. Сравни с пулом gateway (MaxConns × число реплик).",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_stat_database_numbackends{datname=\"ledger\"}",
          "legendFormat": "подключения"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_settings_max_connections",
          "legendFormat": "лимит max_connections"
        }
      ]
    },
    {
      "id": 5,
      "title": "Postgres: транзакции / сек (commit vs rollback)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_xact_commit{datname=\"ledger\"}[1m])",
          "legendFormat": "commit/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"ledger\"}[1m])",
          "legendFormat": "rollback/s"
        }
      ]
    },
    {
      "id": 6,
      "title": "Postgres: строки изменены / сек",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_tup_inserted{datname=\"ledger\"}[1m])",
          "legendFormat": "insert/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_tup_updated{datname=\"ledger\"}[1m])",
          "legendFormat": "update/s"
        }
      ]
    },
    {
      "id": 7,
      "title": "Postgres: ожидания блокировок (lock waits)",
      "description": "Растёт при конкуренции за одни и те же счета.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_deadlocks{datname=\"ledger\"}[1m])",
          "legendFormat": "deadlock/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_locks_count{datname=\"ledger\"}",
          "legendFormat": "locks {{mode}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Redis: подключённые клиенты",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 21 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_connected_clients{job=\"redis\"}",
          "legendFormat": "clients"
        }
      ]
    },
    {
      "id": 9,
      "title": "Redis: команд / сек",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(redis_commands_processed_total{job=\"redis\"}[1m])",
          "legendFormat": "commands/s"
        }
      ]
    },
    {
      "id": 10,
      "title": "Redis: память",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "used"
        }
      ]
    }
  ]
}
